# ==========================================================================
# EBE Apostilas — Modelo de variáveis de ambiente (.env.example)
# ==========================================================================
# Copie este ficheiro para ".env" apenas em ambiente de desenvolvimento
# LOCAL. NUNCA faça commit do ficheiro ".env" real — ele está listado no
# .gitignore.
#
# Em produção (GitHub Actions), NÃO utilize ficheiros .env: configure estas
# mesmas variáveis como GitHub Secrets em
# Settings → Secrets and variables → Actions → New repository secret,
# e injecte-as no workflow via `env:` (ver .github/workflows ou
# workflows_ready/).
# ==========================================================================

# --- Credencial obrigatória (OBTENHA GRATUITAMENTE em https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=

# --- Modelos Gemini ---
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.0-flash

# --- Controlo de limites da API gratuita (margens de segurança) ---
GEMINI_RPM_LIMIT=8
GEMINI_TPM_LIMIT=200000
GEMINI_RPD_LIMIT=180
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_TEMPERATURE=0.85

# --- Retry / backoff exponencial ---
RETRY_MAX_ATTEMPTS=6
RETRY_INITIAL_BACKOFF_SECONDS=4.0
RETRY_MAX_BACKOFF_SECONDS=120.0
RETRY_BACKOFF_MULTIPLIER=2.0

# --- Produção diária ---
APOSTILAS_POR_EXECUCAO=11
